---
/**
 * PortfolioCard — one solution tile on /portfolio.
 * Thumbnail (image or initials fallback), optional status badge, title,
 * summary, tech badges, and the action links that exist (missing ones hidden).
 * The whole card links to the detail page; action links open their targets.
 */
import Badge from '../blog/Badge.astro';
import { statusBadge, actionLinks, initialsOf } from '../../lib/solution';
import type { CollectionEntry } from 'astro:content';

interface Props {
  solution: CollectionEntry<'portfolio'>;
}
const { solution } = Astro.props;
const d = solution.data;
const status = statusBadge(d.status);
const links = actionLinks(d);
const href = `/portfolio/${solution.id}/`;
---

<article
  class="card flex flex-col overflow-hidden rounded-[16px] border border-[var(--border)] bg-[var(--bg-card)] shadow-[var(--shadow)] transition-transform hover:-translate-y-[3px] hover:border-[var(--accent)]"
>
  <!-- Thumbnail (links to detail) -->
  <a href={href} class="relative block">
    {
      d.image ? (
        <img src={d.image} alt={d.title} class="h-[150px] w-full object-cover" />
      ) : (
        <div class="thumb-fallback grid h-[150px] place-items-center text-[34px] font-extrabold tracking-[-0.03em] text-[var(--accent)] opacity-85">
          {initialsOf(d.title)}
        </div>
      )
    }
    {
      status && (
        <span class="absolute top-3 right-3">
          <Badge variant={status.variant} label={status.label} />
        </span>
      )
    }
  </a>

  <div class="flex flex-1 flex-col p-[22px]">
    <h3 class="text-[18px] font-semibold tracking-[-0.01em]">
      <a href={href} class="hover:text-[var(--accent)]">{d.title}</a>
    </h3>
    <p class="mt-1.5 text-[14px] text-[var(--text-muted)]">{d.summary}</p>

    {
      d.tech.length > 0 && (
        <div class="mt-3.5 flex flex-wrap gap-1.5">
          {d.tech.map((t) => (
            <span class="rounded-md border border-[var(--border)] bg-[var(--bg-subtle)] px-2 py-0.5 font-mono text-[11.5px] text-[var(--text-muted)]">
              {t}
            </span>
          ))}
        </div>
      )
    }

    {
      links.length > 0 && (
        <div class="mt-auto flex flex-wrap gap-2 pt-[18px]">
          {links.map((l) => (
            <a
              href={l.href}
              class:list={[
                'inline-flex flex-1 items-center justify-center gap-1.5 rounded-[9px] border px-2 py-2 text-[13px] font-medium whitespace-nowrap',
                l.primary
                  ? 'border-[var(--accent)] bg-[var(--accent)] text-white hover:bg-[var(--accent-hover)]'
                  : 'border-[var(--border)] text-[var(--text)] hover:border-[var(--accent)]',
              ]}
            >
              {l.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</article>
