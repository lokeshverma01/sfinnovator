---
/**
 * AuthorIntro — the "about me" header at the top of /portfolio.
 * Avatar (real photo or initials fallback), name, role, bio, and quick links.
 * All content comes from AUTHOR in consts.ts — edit there, not here.
 */
import { AUTHOR } from '../../consts';
---

<section class="grid grid-cols-1 items-center gap-6 pt-12 sm:grid-cols-[96px_1fr]">
  {
    AUTHOR.photo ? (
      <img
        src={AUTHOR.photo}
        alt={AUTHOR.name}
        width="96"
        height="96"
        class="h-24 w-24 rounded-[20px] border border-[var(--border)] object-cover"
      />
    ) : (
      <div class="thumb-fallback grid h-24 w-24 place-items-center rounded-[20px] border border-[var(--border)] text-[34px] font-extrabold text-[var(--accent)]">
        {AUTHOR.initials}
      </div>
    )
  }

  <div>
    <h1 class="text-3xl font-bold tracking-[-0.02em]">{AUTHOR.name}</h1>
    <div class="mt-0.5 text-sm font-semibold text-[var(--accent)]">{AUTHOR.role}</div>
    <p class="mt-2 max-w-2xl text-[15px] text-[var(--text-muted)]">{AUTHOR.bio}</p>

    {
      AUTHOR.links.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2.5">
          {AUTHOR.links.map((l) => (
            <a
              href={l.href}
              class="rounded-lg border border-[var(--border)] px-3 py-1.5 text-[13px] hover:border-[var(--accent)] hover:text-[var(--accent)]"
            >
              {l.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
