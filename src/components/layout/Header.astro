---
/**
 * Header — logo/wordmark, primary nav, and the theme toggle.
 * Sticky, minimal, with a subtle bottom border.
 */
import Container from '../ui/Container.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
import { SITE, NAV_LINKS } from '../../consts';
---

<header
  class="sticky top-0 z-50 border-b border-[var(--border)] bg-[var(--bg)]/80 backdrop-blur"
>
  <Container>
    <div class="flex h-16 items-center justify-between">
      <!-- Wordmark -->
      <a
        href="/"
        class="text-base font-semibold tracking-tight hover:text-[var(--color-accent)]"
      >
        {SITE.name}
      </a>

      <!-- Nav + toggle -->
      <nav class="flex items-center gap-1 sm:gap-2">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="rounded-md px-3 py-2 text-sm text-[var(--text-muted)] hover:text-[var(--text)] hover:bg-[var(--bg-subtle)]"
            >
              {link.label}
            </a>
          ))
        }
        <span class="ml-1"><ThemeToggle /></span>
      </nav>
    </div>
  </Container>
</header>
