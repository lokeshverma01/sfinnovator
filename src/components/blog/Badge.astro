---
/**
 * Badge — small pill showing a post's type or a debugging status.
 * Colour comes from class-based variants in global.css (.badge-*), so it's
 * CSP-safe (no inline styles). The dot inherits the text colour.
 *
 * Props:
 *   variant: impl | usecase | debug | solved | workaround | investigating
 *   label:   text to show
 *   dot:     show the leading status dot (default true)
 */
interface Props {
  variant: 'impl' | 'usecase' | 'debug' | 'solved' | 'workaround' | 'investigating';
  label: string;
  dot?: boolean;
}
const { variant, label, dot = true } = Astro.props;
---

<span
  class:list={[
    'inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-[11.5px] font-semibold',
    `badge-${variant}`,
  ]}
>
  {dot && <span class="h-1.5 w-1.5 rounded-full bg-current" />}
  {label}
</span>
