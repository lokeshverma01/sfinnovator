---
/**
 * SearchBox — instant static search powered by Pagefind.
 *
 * How it works:
 *   - `npm run build` runs Astro then `pagefind --site dist`, which scans the
 *     built post pages (marked with data-pagefind-body) and writes a tiny
 *     search index + UI bundle to /pagefind/.
 *   - Here we load that UI and mount it onto #search. Everything runs in the
 *     browser from same-origin static files — NO database, NO server.
 *
 * Note: the /pagefind/ bundle only exists AFTER a build, so search works in
 * `npm run preview` and in production — not in `npm run dev`.
 */
---

<div id="search" class="pf-search"></div>

<!-- Pagefind UI styles + script (same-origin static assets from the build). -->
<link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>

<script>
  // Processed (bundled, CSP-hashed) init. Runs after the inline loader above,
  // so the PagefindUI global is available. Guarded so it no-ops if the bundle
  // is missing (e.g. during `astro dev`, where there is no index yet).
  function initPagefind() {
    const PagefindUI = (window as any).PagefindUI;
    if (!PagefindUI) return;
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      resetStyles: false,
      placeholder: 'Search posts…',
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPagefind);
  } else {
    initPagefind();
  }
</script>
