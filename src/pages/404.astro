---
/**
 * 404 — friendly not-found page. Static hosts (Azure SWA, Cloudflare Pages)
 * serve this automatically for unknown routes.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
---

<BaseLayout title="Page not found" noindex={true}>
  <Container class="py-32 text-center">
    <p class="text-sm font-medium text-[var(--color-accent)]">404</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight">This page doesn’t exist.</h1>
    <p class="mt-4 text-[var(--text-muted)]">
      The page you’re looking for moved or was never here.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-md bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white hover:bg-[var(--color-accent-hover)]"
    >
      Back home
    </a>
  </Container>
</BaseLayout>
