---
/**
 * /blog/<slug> — renders a single post through the BlogPost template.
 *
 * getStaticPaths pre-generates one static page per non-draft post at build
 * time. The post's MDX body is rendered to <Content/>, and its headings feed
 * the Table of Contents.
 */
import { getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BlogPost data={post.data} headings={headings} body={post.body}>
  <Content />
</BlogPost>
