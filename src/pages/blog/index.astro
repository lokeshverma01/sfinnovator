---
/**
 * /blog — blog listing page. SKELETON for now.
 * Phase 2 will query the content collection and render post cards here.
 * Kept as a real, indexable page so the nav link works today.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
---

<BaseLayout title="Blog" description="Salesforce implementations, use cases, and debugging guides.">
  <Container class="py-24">
    <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
    <p class="mt-4 text-[var(--text-muted)]">
      Posts are on the way. This is where the article list will live.
    </p>
  </Container>
</BaseLayout>
