---
/**
 * /portfolio — project showcase. SKELETON for now.
 * Phase 3 will render your Salesforce solutions with live links/embeds.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/ui/Container.astro';
---

<BaseLayout title="Portfolio" description="Salesforce solutions you can view, use, and validate.">
  <Container class="py-24">
    <h1 class="text-3xl font-bold tracking-tight">Portfolio</h1>
    <p class="mt-4 text-[var(--text-muted)]">
      Selected Salesforce builds will appear here — viewable and verifiable.
    </p>
  </Container>
</BaseLayout>
