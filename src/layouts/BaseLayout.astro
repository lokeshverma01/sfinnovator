---
/**
 * BaseLayout — the shell for every page.
 * Responsibilities:
 *   - <head>: SEO meta, Open Graph, Twitter, canonical, JSON-LD
 *   - No-flash dark/light theme bootstrap (runs before paint)
 *   - Shared Header + Footer + <main> slot
 */
import '../styles/global.css';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { buildSeo, type SeoInput } from '../lib/seo';
import { SITE } from '../consts';
import { PREPAINT_THEME_SCRIPT } from '../lib/themeScript.mjs';
import { isIndexable } from '../lib/env';

type Props = SeoInput;

const seo = buildSeo({ ...Astro.props, pathname: Astro.url.pathname });
// Rich JSON-LD graph (BlogPosting/WebSite + optional BreadcrumbList) from seo.ts.
const jsonLd = seo.jsonLd;

// Search-engine indexing is AUTOMATIC by environment (see lib/env.ts):
// only production (SEO_INDEX=true) is indexable; previews/local are noindex.
// A page can still force noindex via its `noindex` prop (e.g. the 404 page).
const noindex = seo.noindex || !isIndexable();
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph (Facebook, LinkedIn, Slack previews) -->
    <meta property="og:type" content={seo.type} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.image} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Article-specific OG (only on posts) -->
    {
      seo.type === 'article' && (
        <>
          {seo.publishedTime && (
            <meta property="article:published_time" content={seo.publishedTime} />
          )}
          {seo.modifiedTime && <meta property="article:modified_time" content={seo.modifiedTime} />}
          <meta property="article:author" content={seo.author} />
        </>
      )
    }

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Sitemap discovery -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!--
      No-flash theme bootstrap.
      Runs synchronously BEFORE the body paints, so there is never a flash of
      the wrong theme. The script body is shared from lib/themeScript.mjs so
      its CSP hash (computed in astro.config.mjs) can never drift from it.
    -->
    <script is:inline set:html={PREPAINT_THEME_SCRIPT} />
  </head>
  <body class="min-h-screen bg-[var(--bg)] text-[var(--text)]">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
